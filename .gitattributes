# Detect text files automatically and normalize their repository representation.
* text=auto

# Cross-platform source, configuration, documentation, and scripts.
*.rs           text eol=lf
*.toml         text eol=lf
*.md           text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.json         text eol=lf
*.xml          text eol=lf
*.sh           text eol=lf
*.bash         text eol=lf
*.zsh          text eol=lf
*.py           text eol=lf
*.ps1          text eol=lf
*.gitignore    text eol=lf
*.gitattributes text eol=lf

# Windows-native command scripts.
*.bat          text eol=crlf
*.cmd          text eol=crlf

# Common large binary assets belong in Git LFS.
*.7z           filter=lfs diff=lfs merge=lfs -text
*.bin          filter=lfs diff=lfs merge=lfs -text
*.bz2          filter=lfs diff=lfs merge=lfs -text
*.dmg          filter=lfs diff=lfs merge=lfs -text
*.gz           filter=lfs diff=lfs merge=lfs -text
*.iso          filter=lfs diff=lfs merge=lfs -text
*.msi          filter=lfs diff=lfs merge=lfs -text
*.rar          filter=lfs diff=lfs merge=lfs -text
*.tar          filter=lfs diff=lfs merge=lfs -text
*.tgz          filter=lfs diff=lfs merge=lfs -text
*.xz           filter=lfs diff=lfs merge=lfs -text
*.zip          filter=lfs diff=lfs merge=lfs -text

